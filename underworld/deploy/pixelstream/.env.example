# Copy to .env and fill in. Used by docker-compose on the GPU host.
PUBLIC_IP=                 # the vast.ai instance public IP (or your domain's A record)
HTTP_PORT=80               # where the signalling frontend is served (the iframe loads this)
SIGNALLING_PORT=8888       # UE5 <-> signalling streamer port
TURN_USER=underworld
TURN_PASS=change-me-please
# Match the UE version you packaged with (UE5.5 -> 5.5 tag):
PSINFRA_IMAGE=ghcr.io/epicgamesext/pixelstreamtinginfrastructure/signalling:5.5
# Optional extra UE args, e.g. -PixelStreamingWebRTCFps=60 -PixelStreamingEncoderMaxQP=20
EXTRA_UE_ARGS=
