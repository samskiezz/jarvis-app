VITE_UNDERWORLD_API_URL=http://localhost:8000
# When unset, AuthGate prompts for the key. When set, the dashboard
# auto-authenticates against /auth/me on load.
VITE_UNDERWORLD_API_KEY=dev-key

# Unreal Pixel Streaming endpoint embedded in WorldDetail (the GPU render tier).
# Pre-wired to the existing GPU host by default; override per-deploy. The
# "Stream UE5" toggle connects here once a Pixel-Streaming signaling server +
# UE5 client are running on the GPU box (see docs/GPU-pixel-streaming.md).
VITE_UNDERWORLD_PIXELSTREAM_URL=https://projectsolar.cloud/pixelstream/
