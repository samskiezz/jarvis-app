VITE_UNDERWORLD_API_URL=http://localhost:8000
VITE_UNDERWORLD_API_KEY=dev-key

# Optional: URL of an Unreal Pixel Streaming endpoint to embed in
# WorldDetail. When unset the "Stream UE5" toggle hides automatically;
# the rest of the page works fine on the R3F renderer.
# VITE_UNDERWORLD_PIXELSTREAM_URL=ws://localhost:8888

# Optional: when true the React app requires VITE_UNDERWORLD_API_KEY to be
# set before rendering the dashboard. Default (unset / false) lets the app
# run open for local dev. See src/lib/AuthGate.jsx.
# VITE_REQUIRE_AUTH=true
