# EditorConfig for the polyglot Enterprise OS monorepo.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# JVM control plane (Java/Kotlin/Gradle).
[*.{java,kt,kts,gradle}]
indent_size = 4

# Go fleet agents.
[*.go]
indent_style = tab
indent_size = 4

# Python reference implementation (Layer A under server/).
[*.py]
indent_size = 4

# Config / contract files.
[*.{yml,yaml,json,toml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
