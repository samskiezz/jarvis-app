# Copy to .env.local and adjust as needed:  cp .env.example .env.local

# ── Backend connection ───────────────────────────────────────────────────────
# Base URL of the FastAPI backend (server/). Live intel, analyst, and the
# tactical SSE streams are all served from here.
VITE_API_BASE_URL=http://localhost:8000

# Sent as `Authorization: Bearer <key>`. Must match the backend JARVIS_API_KEY.
# Optional in local/playable mode (the public read endpoints are open by default).
VITE_API_KEY=dev-key

# Force the login gate even in local builds (default: false / playable).
VITE_REQUIRE_AUTH=false

# ── Live tactical streams (optional overrides) ───────────────────────────────
# Leave unset to stream from the bundled backend at
# `${VITE_API_BASE_URL}/streams/panopticon` and `/streams/counterstrike`.
# Set these only to point the 3D panels at an external telemetry feed.
# VITE_PANOPTICON_STREAM_URL=
# VITE_COUNTERSTRIKE3D_STREAM_URL=

# ── Optional 3D render assets (Three.js LiveTactical3D) ───────────────────────
# All optional — the scene renders a procedural terrain + units without them.
# VITE_RENDER_HDRI_URL=
# VITE_RENDER_GRASS_ALBEDO_URL=
# VITE_RENDER_DIRT_ALBEDO_URL=
# VITE_ASSET_SOURCE_QUANTINIUM=
# VITE_ASSET_SOURCE_SKETCHFAB=
# VITE_ASSET_SOURCE_POLYHAVEN=
