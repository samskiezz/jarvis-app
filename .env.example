# Jarvis backend URL — the FastAPI service. Defaults to localhost:8000.
VITE_API_BASE_URL=http://localhost:8000

# API key validated by the backend at /auth/me. Match server's JARVIS_API_KEY.
VITE_API_KEY=dev-key

# Optional: HDR / texture sources for the LiveTactical3D panels.
# VITE_RENDER_HDRI_URL=
# VITE_RENDER_GRASS_ALBEDO_URL=
# VITE_RENDER_DIRT_ALBEDO_URL=

# Optional: SSE stream endpoints for the simulation panels (off by default).
# VITE_PANOPTICON_STREAM_URL=
# VITE_COUNTERSTRIKE3D_STREAM_URL=
