# ── GPU Compute Tier (Vast.ai 2× RTX 4090) ────────────────────────────────────
# The GPU box runs Ollama (not SGLang) on host port 41137 (container port 8080).
# Copy these into your shell environment or .env file, then restart JARVIS.
# When OLLAMA_HOST points to a non-localhost address, Ollama is promoted to
# PRIMARY in the LLM fallback chain and embeddings use the GPU first.

# Ollama API on the GPU box (direct, no auth needed)
OLLAMA_HOST=http://211.72.13.201:41137
OLLAMA_BASE_URL=http://211.72.13.201:41137

# Default chat model on the GPU (8B parameter, fast on RTX 4090)
OLLAMA_MODEL=llama3.1:8b

# Embedding model on the GPU (137M parameter, 768-dim)
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# ── SGLang GPU tier (future-proofing; not active on this box) ──────────────────
# When GPU_BASE_URL is set, the unified gpu_compute dispatcher uses SGLang.
# Kept for future GPU boxes that run SGLang instead of Ollama.
GPU_BASE_URL=
GPU_AUTH_TOKEN=
GPU_EMBED_MODEL=

# ── Legacy GPU prediction tier (PyTorch GRU server) ───────────────────────────
# Kept for backward compatibility with deploy/gpu/server.py
PREDICT_GPU_URL=
PREDICT_GPU_KEY=
PREDICT_GPU_MODEL=
