# Backend caches + REGENERATED runtime data ONLY. These are rebuilt by setup.sh /
# autobuild on every box, so they don't belong in git (committing them bloats the repo
# and breaks pulls). ALL real CONFIG is committed — .env, .env.*, llm_connect.json,
# IPs/ports/flags — so `git pull` brings the full working setup to every box.
server/__pycache__/
server/**/__pycache__/
server/*.db
server/data/*.db
server/data/*.db-wal
server/data/*.db-shm
server/.pytest_cache/
.pytest_cache/

# APEX Forge runtime (locks + backups)
.forge/
__pycache__/
*.pyc
sandbox-ca.crt
server/data/oracle_model.joblib
underworld/data/*.db
underworld/data/*.db-*
