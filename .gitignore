# Backend caches + REGENERATED runtime data ONLY. These are rebuilt by setup.sh /
# autobuild on every box, so they don't belong in git (committing them bloats the repo
# and breaks pulls). ALL real CONFIG is committed — .env, .env.*, llm_connect.json,
# IPs/ports/flags — so `git pull` brings the full working setup to every box.
server/__pycache__/
server/**/__pycache__/
server/*.db
server/data/*.db
server/data/*.db-wal
server/data/*.db-shm
server/.pytest_cache/
.pytest_cache/

# APEX Forge runtime (locks + backups)
.forge/
__pycache__/
*.pyc
sandbox-ca.crt
server/data/oracle_model.joblib
underworld/data/*.db
underworld/data/*.db-*

# regenerable design directive table (262MB, rebuild via design_spec.py)
underworld/data/design/render_directives.csv
underworld/data/design/stories.csv
underworld/data/design/sciences.csv

# secrets — never commit
.tripo_env

.openai_env
.kimi_env

# Image-first 3D regeneration output — 12GB+ of GLBs/PNGs from the GPT-Image→Tripo pipeline.
# Large binaries that jam `git add -A` and would push the (already 7.3GB) repo past ~19GB and
# break clones — the same blunder this file guards against. The repo already carries the older
# generated/tripo + Kenney kits; this NEW set belongs on a CDN / Git-LFS (Bible EPIC I1
# 'assets-to-CDN'). Regenerate via scripts/tripo_imagefirst.py. Narrow scope, not a global *.glb.
underworld/web/public/models/generated/uw/
_old_textfirst_glbs/
test_crate.glb

# Overnight build — large GENERATED outputs (rebuilt by pipelines; keep out of git history)
jarvis_assets/
dist_prev/
design_pack/
underworld/deploy/ue5-project/Saved/
*.db-journal
*.tmp.*

# UE5 build artifacts (regenerated by the engine; keep source + imported Content only)
underworld/deploy/ue5-project/Binaries/
underworld/deploy/ue5-project/Intermediate/
underworld/deploy/ue5-project/DerivedDataCache/
underworld/deploy/ue5-project/Content/JarvisAssets/
