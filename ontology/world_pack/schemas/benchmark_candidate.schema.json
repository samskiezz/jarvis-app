{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.internal/schemas/benchmark-candidate.schema.json",
  "title": "BenchmarkCandidate",
  "type": "object",
  "required": [
    "benchmark_candidate_id",
    "subject_id",
    "benchmark_name",
    "benchmark_url",
    "metrics",
    "acceptance_gate"
  ],
  "properties": {
    "benchmark_candidate_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "benchmark_name": {
      "type": "string"
    },
    "benchmark_url": {
      "type": "string",
      "format": "uri"
    },
    "metrics": {
      "type": "string"
    },
    "acceptance_gate": {
      "type": "string"
    }
  }
}