{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.internal/schemas/endpoint-candidate.schema.json",
  "title": "EndpointCandidate",
  "type": "object",
  "required": [
    "endpoint_candidate_id",
    "subject_id",
    "source_id",
    "official_url",
    "access_method",
    "recommended_ingestion_connector",
    "licence_review_required"
  ],
