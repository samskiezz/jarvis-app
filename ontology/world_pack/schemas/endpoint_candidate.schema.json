    "endpoint_candidate_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "official_url": {
      "type": "string",
      "format": "uri"
    },
    "access_method": {
      "type": "string"
    },
    "recommended_ingestion_connector": {
      "type": "string"
    },
    "parser_strategy": {
      "type": "string"
    },
    "refresh_cadence": {
      "type": "string"
    },
    "licence_review_required": {
      "type": "string"
