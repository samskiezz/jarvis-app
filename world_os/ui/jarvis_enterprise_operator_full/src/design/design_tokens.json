{
  "brand": {
    "name": "Jarvis Enterprise Operator",
    "tone": "high-density, calm, tactical, evidence-led, non-cheesy",
    "visual_principles": [
      "minimal chrome",
      "high contrast dark cockpit",
      "data first",
      "no random decorative lines",
      "each glow/effect must indicate status, confidence, selection or urgency"
    ]
  },
  "colors": {
    "bg_base": "#05070D",
    "bg_panel": "rgba(7, 15, 29, 0.78)",
    "bg_panel_solid": "#07101D",
    "border_subtle": "rgba(120, 210, 255, 0.22)",
    "text_primary": "#E8F2FF",
    "text_secondary": "#9FB6CA",
    "foundry": "#00D4FF",
    "gotham": "#FF3B6B",
    "apollo": "#7CFF7C",
    "aip": "#B18CFF",
    "success": "#55E6A5",
    "warning": "#FFD166",
    "danger": "#FF5C7A",
    "blocked": "#8A1C2D",
    "audit": "#8BE9FD",
    "evidence": "#4DD8FF"
  },
  "effects": {
    "panel_blur": "backdrop-filter: blur(18px); transform: translateZ(0);",
    "selection_glow": "0 0 18px rgba(0, 212, 255, 0.42)",
    "critical_glow": "0 0 24px rgba(255, 92, 122, 0.55)",
    "success_glow": "0 0 20px rgba(85, 230, 165, 0.40)",
    "reduced_motion": "disable large camera sweeps, replace with fade/scale"
  },
  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 12,
    "lg": 18,
    "xl": 28
  },
  "typography": {
    "font_stack": "Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto",
    "density": "compact",
    "body_size": 13,
    "caption_size": 11,
    "title_size": 16
  },
  "status_meaning": {
    "cyan": "selected, inspected, Foundry/data",
    "red": "Gotham operational alert/risk",
    "green": "Apollo healthy/deployed",
    "purple": "AIP/generated/model context",
    "yellow": "warning/pending approval",
    "grey": "inactive/unknown"
  }
}