# APEX frontend (Vite/React SPA) — production static image served by nginx.
# Build: `vite build` -> dist/, then served as static files with SPA fallback.

# ── Stage 1: build the SPA ───────────────────────────────────────────────────
FROM node:20-slim AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
# Optional: point the SPA at your backend at build time.
#   docker build -f Dockerfile.web --build-arg VITE_API_BASE_URL=https://api.example.com .
ARG VITE_API_BASE_URL
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
RUN npm run build           # → /app/dist

# ── Stage 2: serve static bundle ─────────────────────────────────────────────
FROM nginx:1.27-alpine AS serve
# SPA fallback: every path resolves to index.html (matches netlify.toml/vercel.json).
RUN printf 'server {\n\
    listen 80;\n\
    root /usr/share/nginx/html;\n\
    index index.html;\n\
    location / {\n\
        try_files $uri $uri/ /index.html;\n\
    }\n\
}\n' > /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
