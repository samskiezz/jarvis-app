# ─────────────────────────────────────────────────────────────────────────────
# COMMITTED DEPLOY CONFIG — pulled live on every box (VPS + vast.ai) via git.
# Sourced by serve.sh / boot.sh before the backend starts. VITE_* values are also
# read automatically by the Vite build.
#
#  NO SECRETS IN THIS FILE. It is committed to the git repo, so anything here is
#  visible to anyone with repo access. `dev-key` is the default OPEN dev key, not a
#  secret. If you ever need a real API key (e.g. KIMI_API_KEY), export it as a shell
#  env var on the box BEFORE running serve.sh — do NOT put it here.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ports (VPS front door: http://76.13.176.135:5173 UI · :8001 API) ─────────
API_PORT=8001
UI_PORT=5173
VITE_API_PORT=8001
VITE_API_KEY=dev-key
VITE_REQUIRE_AUTH=false

# ── vast.ai GPU box — SSH connection (stored so the app/helper can re-link) ──
# Private KEY stays on the box (vast.ai uses key auth) — never committed. These ports
# change when the instance is recreated; update + `git push` and every box picks them up.
#   direct: ssh -p 16798 root@ssh5.vast.ai   -L 11434:localhost:11434   (instance 40566798)
#   (vast SSH host is already a stable proxy name; no separate proxy needed)
# NOTE: Vast reassigns SSH host:port on every instance restart. The live brain is now
# auto-discovered via the Vast API in gpu_instances.ensure_brain_tunnel() (canonical).
# These are only used by the manual scripts/gpu-link.sh — kept current as a convenience.
VAST_SSH_HOST=220.130.209.122
VAST_SSH_PORT=39450
VAST_SSH_PROXY_HOST=220.130.209.122
VAST_SSH_PROXY_PORT=39450
VAST_SSH_USER=root
VAST_OLLAMA_PORT=11434
# Two ways to connect the GPU (either works):
#  • GPU_LINK=1 → serve.sh tunnels Ollama from the box to 127.0.0.1:11434 over SSH using
#    the VAST_SSH_* above (needs the VPS to hold your SSH key; tries direct then proxy).
#  • or run scripts/vast-register.sh ON the box (no SSH needed; it self-registers).
GPU_LINK=1
# Current box = single RTX 4090 (24GB) in Taiwan (~70ms RTT to the KL VPS vs Montreal's 750ms).
# One card runs brain (qwen2.5:14b ~9GB) + XTTS voice (~2GB) together comfortably, so both pin to GPU0.
OLLAMA_VISIBLE_GPUS=0
XTTS_GPU_INDEX=0
VOICE_LINK=1

# ── GPU LLM on vast.ai (211.72.13.201) ───────────────────────────────────────
# vast.ai maps the container's :11434 to a DIFFERENT external port that changes
# whenever the instance is recreated. Two steps to connect:
#   1) On the GPU box, bind Ollama to all interfaces (not just localhost):
#        OLLAMA_HOST=0.0.0.0:11434 ollama serve &
#        ollama pull llama3.1:8b
#   2) Get the external port mapped to 11434, then set OLLAMA_HOST below:
#        echo "$VAST_TCP_PORT_11434"      # vast.ai sets this on the box
#   …or skip editing this file and just use the Setup page → "Connect GPU" (it
#    persists to llm_connect.json, which is also committed, so the URL syncs too).
# The self-healing SSH tunnel (gpu-link.sh) maps the box's :11434 to 127.0.0.1:11434
# here, so the endpoint is port-map independent — no external port to chase.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
# Tier ladder (server/services/tiered_llm.py). Everyday chat uses tier 'strong' — set to the FAST 14b so
# replies are ~1-2s and the model stays resident on GPU0 (32b is ~7s and too big to also keep 14b warm).
# Deep reasoning bursts to a TEMP destroyable instance per tier (heavy=70b) — bigger power only when needed.
OLLAMA_BASE_MODEL=llama3.1:8b
OLLAMA_STRONG_MODEL=qwen2.5:14b
HEAVY_MODEL=llama3.3:70b
LLM_ENABLE_70B=1
# User-facing chat hard timeout (s). 14b warm is ~1-2s; the headroom only matters on a cold model load.
JARVIS_DASHBOARD_CHAT_TIMEOUT_S=20

# ── Autonomous engines (GPU autopilot, autobuild, recon allowlist) ───────────
# CONSERVATIVE autopilot: the GPU-busy research loop is OFF by default so it can
# never silently chew VRAM/GPU. Run it on demand by setting this to 1.
LLM_AUTOPILOT_ENABLE=0
LLM_AUTOPILOT_CONCURRENCY=3
# Proactive notifications (cheap, rule-based) are the one always-on "essential"
# loop. Its optional LLM synthesis stays off unless PROACTIVE_LLM_SUMMARY=1.
PROACTIVE_LOOP_ENABLED=true
PROACTIVE_LOOP_INTERVAL=180
AUTOBUILD_BATCHES=2
AUTOBUILD_OCR=5
# Recon tools (katana/nuclei/etc.) only run against hosts you list here (your own /
# authorised assets). Empty/default = recon off against third parties.
RECON_ALLOWLIST=127.0.0.1,localhost
